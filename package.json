{
  "name": "portfolio-monorepo",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "vault": "npm run dev --workspace=apps/vault",
    "slice": "npm run dev --workspace=apps/slice",
    "dev": "concurrently \"npm run vault\" \"npm run slice\"",
    "build": "npm run build --workspaces",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
