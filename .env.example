# ============================================================
# Copy this to apps/vault/.env.local AND apps/slice/.env.local
# Fill in your own values
# ============================================================

# Supabase (same project, both apps)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Anthropic Claude API (SLICE only - scan struk)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================
# SETUP STEPS:
# 1. Buat project di https://supabase.com
# 2. Jalankan schema.sql di SQL Editor Supabase
# 3. Enable Google OAuth di Authentication > Providers
#    - Callback URL: https://YOUR_PROJECT.supabase.co/auth/v1/callback
# 4. Get API key di https://console.anthropic.com
# 5. Isi nilai di atas
# ============================================================
